---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import { link } from '../../lib/path';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews', ({ data }) => !data.draft);
  return reviews.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'reviews'> };

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const url = link(`/reviews/${entry.id}`);
---

<ReviewLayout entry={entry} url={url}>
  <Content />
</ReviewLayout>
