---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import { readingTime } from '../../lib/reading-time';
import { SITE } from '../../lib/site';
import { link } from '../../lib/path';

const all = await getCollection('reviews', ({ data }) => !data.draft);
const sorted = all.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="All reviews"
  description={`Every review published on ${SITE.title}.`}
  type="website"
>
  <section class="reviews-index container-narrow">
    <header class="reviews-index__header">
      <p class="eyebrow">Index</p>
      <h1>All reviews</h1>
      <p class="reviews-index__count">
        {sorted.length} {sorted.length === 1 ? 'review' : 'reviews'} published.
      </p>
    </header>

    <div class="reviews-index__list">
      {sorted.map((entry) => (
        <ReviewCard
          href={link(`/reviews/${entry.id}`)}
          title={entry.data.title}
          description={entry.data.description}
          publishDate={entry.data.publishDate}
          readingTime={readingTime(entry.body ?? '')}
          rating={entry.data.rating}
          productCategory={entry.data.productCategory}
        />
      ))}

      {sorted.length === 0 && (
        <p>No reviews yet. Check back soon.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-index {
    padding-block: var(--space-7) var(--space-8);
  }

  .reviews-index__header {
    margin-bottom: var(--space-6);
  }

  .reviews-index__header .eyebrow {
    margin-bottom: var(--space-3);
  }

  .reviews-index__header h1 {
    font-family: var(--font-display);
    font-weight: 500;
    margin: 0 0 var(--space-3) 0;
  }

  .reviews-index__count {
    color: var(--color-ink-soft);
  }
</style>
