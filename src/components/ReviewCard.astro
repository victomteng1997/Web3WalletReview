---
type Props = {
  href: string;
  title: string;
  description: string;
  publishDate: Date;
  readingTime?: string;
  rating?: number;
  productCategory?: string;
  featured?: boolean;
};

const {
  href,
  title,
  description,
  publishDate,
  readingTime,
  rating,
  productCategory,
  featured = false,
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class={`review-card${featured ? ' review-card--featured' : ''}`}>
  <a class="review-card__link" href={href} aria-label={title}>
    <div class="review-card__meta">
      {productCategory && <span class="eyebrow">{productCategory}</span>}
      {typeof rating === 'number' && (
        <span class="review-card__rating" aria-label={`Rating: ${rating} out of 10`}>
          {rating.toFixed(1)}
        </span>
      )}
    </div>
    <h2 class="review-card__title">{title}</h2>
    <p class="review-card__desc">{description}</p>
    <div class="review-card__foot">
      <time datetime={publishDate.toISOString()}>
        {dateFormatter.format(publishDate)}
      </time>
      {readingTime && (
        <>
          <span aria-hidden="true">·</span>
          <span>{readingTime}</span>
        </>
      )}
    </div>
  </a>
</article>

<style>
  .review-card {
    border-top: 1px solid var(--color-rule);
    padding-block: var(--space-5);
  }

  .review-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
    margin-inline: calc(var(--space-4) * -1);
    padding: var(--space-4);
    border-radius: var(--card-radius);
    transition: background 140ms ease, transform 140ms ease;
  }

  .review-card__link:hover {
    background: var(--color-paper-elevated);
    transform: translateY(var(--card-hover-y));
  }

  .review-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .review-card__rating {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-accent);
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    padding: 0.05em 0.55em;
  }

  .review-card__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-2) 0;
    letter-spacing: 0;
  }

  .review-card__link:hover .review-card__title,
  .review-card__link:hover .review-card__foot::after {
    color: var(--color-accent);
  }

  .review-card__desc {
    color: var(--color-ink-soft);
    font-size: 1rem;
    line-height: 1.55;
    margin-bottom: var(--space-3);
    max-width: 42em;
  }

  .review-card__foot {
    color: var(--color-ink-muted);
    font-size: 0.85rem;
    display: flex;
    gap: var(--space-2);
    align-items: baseline;
  }

  .review-card__foot::after {
    content: 'Read review';
    margin-left: auto;
    color: var(--color-ink-muted);
    transition: color 140ms ease;
  }

  .review-card--featured {
    border-top: 0;
    padding-block: 0 var(--space-6);
  }

  .review-card--featured .review-card__title {
    font-size: clamp(2rem, 3vw + 0.75rem, 2.75rem);
    line-height: 1.1;
    margin-bottom: var(--space-3);
  }

  .review-card--featured .review-card__desc {
    font-size: 1.125rem;
    max-width: 36em;
  }
</style>
