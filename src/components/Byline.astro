---
import { link } from '../lib/path';

type Props = {
  author: string;
  publishDate: Date;
  readingTime?: string;
  authorHref?: string;
};

const { author, publishDate, readingTime, authorHref = link('/about') } =
  Astro.props;

const formatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const human = formatter.format(publishDate);
const iso = publishDate.toISOString();
---

<address class="byline">
  By <a href={authorHref} rel="author">{author}</a>
  <span class="byline__sep">·</span>
  <time datetime={iso}>{human}</time>
  {readingTime && (
    <>
      <span class="byline__sep">·</span>
      <span>{readingTime}</span>
    </>
  )}
</address>

<style>
  .byline {
    font-style: normal;
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    align-items: baseline;
  }

  .byline a {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }
  .byline a:hover {
    border-bottom-color: var(--color-accent);
    color: var(--color-accent);
  }

  .byline__sep {
    color: var(--color-ink-muted);
  }
</style>
