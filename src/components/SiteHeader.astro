---
import { SITE } from '../lib/site';
import { link } from '../lib/path';

const path = Astro.url.pathname;
const home = link('/');
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={home} class="site-header__wordmark" aria-label={`${SITE.title} home`}>
      <span class="wordmark">{SITE.title}</span>
    </a>
    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {SITE.navLinks.map((navItem) => {
          const href = link(navItem.href);
          const active = href === home
            ? path === home
            : path.startsWith(href);
          return (
            <li>
              <a href={href} aria-current={active ? 'page' : undefined}>
                {navItem.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-rule);
    padding-block: var(--space-5);
    background: var(--color-paper);
  }

  .site-header__inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-5);
  }

  .site-header__wordmark {
    text-decoration: none;
    color: var(--color-ink);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    letter-spacing: 0;
  }

  .site-header__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: var(--space-5);
  }

  .site-header__nav a {
    color: var(--color-ink-soft);
    font-size: 0.95rem;
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    color: var(--color-ink);
    border-bottom-color: var(--color-accent);
  }

  @media (max-width: 520px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
    .site-header__nav ul {
      gap: var(--space-4);
    }
  }
</style>
